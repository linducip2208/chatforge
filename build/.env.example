# ChatGo — Environment Configuration
# Copy ke .env dan sesuaikan

# MySQL Connection
CHATGO_MYSQL=root:password@tcp(127.0.0.1:3306)/chatgo?charset=utf8mb4&parseTime=true

# AES-256 Encryption Key (WAJIB diganti, 32 karakter minimum)
# Generate: openssl rand -base64 32
CHATGO_ENC_KEY=Po1rrPiy+Z+cx9DeSYXDmYPTEZGbeJjdBUAEq3m6Dp8=

# App URL (untuk callback payment, OG tags, dll)
APP_URL=https://chatgo.domain.com

# App Identity
APP_NAME=ChatGo
APP_EMAIL=admin@domain.com
APP_LOGO=/assets/theme/default-logo-light.png
